{
  // Appearance
  "theme": "One Dark",
  "buffer_font_size": 14,
  "buffer_font_family": "Hack Nerd Font",
  "buffer_font_fallbacks": ["D2Coding"],
  "ui_font_family": ".SystemUIFont",

  // Editor
  "format_on_save": "off",
  "soft_wrap": "editor_width",
  "ensure_final_newline_on_save": false,
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "toolbar": { "quick_actions": false, "breadcrumbs": false },

  // Languages & Tools
  "languages": {
    "HTML": { "tab_size": 2 },
    "CSS": { "tab_size": 2 },
    "Svelte": { "tab_size": 2 },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": { "enabled": "always" },
        },
        "javascript": {
          "updateImportsOnFileMove": { "enabled": "always" },
        },
      },
      "enable_lsp_tasks": true,
    },
  },

  // Window & Layout
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "title_bar": { "show_user_picture": false },
  "tabs": { "file_icons": true },
  "diagnostics": { "button": false },
  "outline_panel": { "button": false },
  "collaboration_panel": { "button": false },
  "debugger": { "button": false },
  "status_bar": { "active_encoding_button": "enabled" },

  // Panels
  "project_panel": { "default_width": 360 },
  "notification_panel": { "button": false },

  // Terminal
  "terminal": {
    "button": false,
    "blinking": "on",
    "cursor_shape": "bar",
    "option_as_meta": true,
    "default_height": 640,
    "shell": { "program": "fish" },
  },

  // Version Control
  "git": { "inline_blame": { "enabled": false } },

  // AI
  "disable_ai": true,

  // Extensions
  "auto_install_extensions": {
    "dockerfile": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "svelte": true,
    "toml": true,
  },

  // Theme
  "theme_overrides": {
    "One Dark": {
      // Background colors
      "background": "#1d2027ff",
      "panel.background": "#1d2027ff",
      "tab_bar.background": "#1d2027ff",
      "tab.inactive_background": "#1d2027ff",
      "status_bar.background": "#1d2027ff",
      "title_bar.background": "#1d2027ff",
      "title_bar.inactive_background": "#1d2027ff",
      "elevated_surface.background": "#1d2027ff",
      "surface.background": "#1d2027ff",

      // Element colors
      "element.hover": "#282c33ff",
      "element.active": "#33383fff",
      "element.selected": "#33383fff",
      "ghost_element.hover": "#282c33ff",
      "ghost_element.active": "#33383fff",
      "ghost_element.selected": "#33383fff",

      // Miscellaneous
      "drop_target.background": "#33383f80",
      "scrollbar.thumb.hover_background": "#c8ccd44c",
      "scrollbar.track.border": "#33383fff",
      "border": "#33383fff",
    },
  },
}
